generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Note {
  id        String      @id @default(uuid())
  title     String
  content   Json
  isPublic  Boolean     @default(false)

  ownerId   String

  shares    NoteShare[]

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model NoteShare {
  id        String   @id @default(uuid())
  
  noteId    String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  
  userEmail String
  role      String   @default("READ") // "READ" or "EDIT"

  createdAt DateTime @default(now())
  
  @@unique([noteId, userEmail])
}
