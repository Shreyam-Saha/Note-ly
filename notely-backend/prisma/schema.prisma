generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Note {
  id        String   @id @default(uuid())
  title     String
  content   Json
  isPublic  Boolean  @default(false)

  ownerId   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
